---
import BaseLayout from '../layouts/BaseLayout.astro';

const verticals = [
  { href: '/sourcing-agencies/', seal: '采', title: 'Sourcing Agencies', desc: 'Win Western Amazon sellers who vet you on LinkedIn before they reply.' },
  { href: '/freight-forwarders/', seal: '运', title: 'Freight Forwarders', desc: 'Turn importers and e-commerce brands into a steady logistics pipeline.' },
  { href: '/software/', seal: '软', title: 'Software / SaaS', desc: 'Fill your demo calendar with supply-chain and e-commerce buyers.' },
  { href: '/factories/', seal: '厂', title: 'Factories', desc: 'Be the manufacturer global brands discover, trust, and reorder from.' },
];
---

<BaseLayout
  title="China Wins Global — LinkedIn pipelines for China's suppliers"
  description="We build the LinkedIn presence and outbound engine that turns Chinese suppliers into the partner Western buyers reach out to first."
>
  <!-- HERO -->
  <section class="chapter chapter--light hero" id="hero">
    <div class="wrap hero__grid">
      <div class="hero__copy">
        <p class="eyebrow"><i></i><span>LinkedIn pipelines for global trade · 深圳 / 广州 / 义乌</span></p>
        <h1 class="hero__title">China makes it.<br />The world should <em>find you.</em></h1>
        <p class="hero__sub">We build the LinkedIn presence and outbound engine that turns Chinese suppliers into the partner Western buyers reach out to first — not the fifteenth business card in the pile.</p>
        <p class="gloss" lang="zh-CN">我们为中国供应商打造领英形象与获客引擎，让西方买家主动找上门 —— 而不是名片堆里的第十五张。</p>
        <div class="hero__ctas">
          <a class="btn btn--primary" href="/contact/">
            <span>Get My Free LinkedIn Audit</span>
            <span class="btn__orb" aria-hidden="true"><svg viewBox="0 0 16 16"><path d="M3 13 13 3M6 3h7v7" fill="none" stroke="currentColor" stroke-width="1.5"/></svg></span>
          </a>
          <a class="link-underline" href="#who">See who we help</a>
        </div>
        <p class="hero__trust">
          <span>Trusted by cross-border suppliers</span>
          <i class="tick" aria-hidden="true"></i>
          <span>30 qualified conversations in 90 days — guaranteed</span>
        </p>
      </div>
      <div class="hero__aside" aria-hidden="true">
        <div class="booth-card shell">
          <div class="core">
            <p class="booth-card__label">Meanwhile, on LinkedIn…</p>
            <div class="msg">
              <span class="msg__avatar">JS</span>
              <div>
                <p class="msg__name">J. Sanders · Amazon FBA, US</p>
                <p class="msg__text">Hi — saw your profile. Do you source kitchen organizers? Looking for a long-term partner.</p>
              </div>
            </div>
            <div class="msg msg--you">
              <span class="msg__avatar msg__avatar--you">你</span>
              <div>
                <p class="msg__name">You · 2 min later</p>
                <p class="msg__text">Yes — that's our main category. 14 factories audited. Here's our catalog…</p>
              </div>
            </div>
            <p class="booth-card__foot"><span class="pulse" aria-hidden="true"></span><span>Conversation started · pipeline stage: warm</span></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHO WE HELP -->
  <section class="chapter chapter--dark" id="who">
    <div class="wrap">
      <p class="eyebrow eyebrow--dark"><i></i><span>Who we help · 服务对象</span></p>
      <h2 class="h2 h2--dark">Four industries. One growth engine.</h2>
      <div class="who__grid">
        {verticals.map((v) => (
          <a class="who__card" href={v.href}>
            <span class="who__seal" aria-hidden="true">{v.seal}</span>
            <h3 class="who__title">{v.title}</h3>
            <p class="who__desc">{v.desc}</p>
            <span class="who__go" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CLOSING CTA -->
  <section class="chapter chapter--light" id="cta">
    <div class="wrap wrap--narrow" style="text-align:center">
      <h2 class="h2">Ready to be the supplier they find first?</h2>
      <p class="hero__sub" style="margin-inline:auto">Start with a free LinkedIn audit. We'll show you exactly what Western buyers see today — and the pipeline you're missing.</p>
      <div class="hero__ctas" style="justify-content:center">
        <a class="btn btn--primary" href="/contact/"><span>Get My Free LinkedIn Audit</span></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .who__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
    margin-top: 2.5rem;
  }
  .who__card {
    position: relative;
    display: block;
    padding: 1.75rem;
    border-radius: 1.25rem;
    background: rgba(247, 243, 236, 0.05);
    border: 1px solid var(--hairline-dark);
    color: var(--cream);
    text-decoration: none;
    transition: transform 0.4s var(--ease), background-color 0.4s var(--ease), border-color 0.4s var(--ease);
  }
  .who__card:hover {
    transform: translateY(-4px);
    background: rgba(247, 243, 236, 0.09);
    border-color: rgba(227, 155, 139, 0.4);
  }
  .who__seal {
    display: inline-grid;
    place-items: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 0.6rem;
    background: var(--red);
    color: #fff7f0;
    font-family: 'Noto Serif SC', serif;
    font-size: 1.15rem;
    margin-bottom: 1rem;
  }
  .who__title { font-family: var(--font-display); font-size: 1.4rem; margin-bottom: 0.5rem; }
  .who__desc { color: rgba(247, 243, 236, 0.6); font-size: 0.95rem; line-height: 1.6; }
  .who__go { position: absolute; top: 1.75rem; right: 1.75rem; color: var(--red-soft); font-size: 1.2rem; }
  @media (max-width: 720px) {
    .who__grid { grid-template-columns: 1fr; }
  }
</style>
