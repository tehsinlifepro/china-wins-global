---
import BaseLayout from '../layouts/BaseLayout.astro';
import AuditForm from '../components/AuditForm.astro';
import { SITE } from '../config';

const mailto = `mailto:${SITE.contact.email}?subject=Free%20headline%20rewrite&body=Here's%20my%20LinkedIn%20profile%20URL:%20`;
---

<BaseLayout
  title="Contact — China Wins Global"
  description="Start with a free LinkedIn audit, or reach us on WeChat. We help Chinese suppliers win global B2B clients on LinkedIn."
>
  <section class="chapter chapter--light">
    <div class="wrap">
      <p class="eyebrow"><i></i><span>Contact · 联系</span></p>
      <h1 class="h2">Let’s build your pipeline.</h1>
      <p class="page-lead">Start with a free LinkedIn audit — we’ll mystery-shop your company as a Western buyer and show you exactly what they see today, and the pipeline you’re missing. Prefer WeChat? Scan and say hi.</p>
      <AuditForm lang="en" />
    </div>
  </section>

  <section class="chapter chapter--dark" id="rewrite">
    <div class="wrap wrap--narrow">
      <p class="eyebrow eyebrow--dark"><i></i><span>Free rewrite · 免费重写</span></p>
      <h2 class="h2 h2--dark">Free: we’ll rewrite your LinkedIn headline + first 3 lines into the words Western buyers search.</h2>
      <p class="rewrite-lede">Your headline is the first thing a Western buyer reads — and usually the reason they don’t reply. Send us your LinkedIn profile URL and we’ll send back:</p>
      <ul class="rewrite-list">
        <li>A rewritten headline built on the keywords buyers actually search for your category</li>
        <li>Your first 3 “About” lines rewritten to open with the buyer’s problem</li>
        <li>One quick note on the single biggest gap we spot</li>
      </ul>
      <p class="rewrite-lede">No call. No form. No cost. Just send your profile link.</p>
      <div class="hero__ctas">
        <a class="btn btn--primary" href={mailto}><span>Email us your LinkedIn URL</span></a>
        <span class="rewrite-alt">or WeChat: <strong>{SITE.contact.wechat}</strong></span>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .rewrite-lede { color: rgba(247, 243, 236, 0.72); line-height: 1.7; margin-top: 1rem; max-width: 44rem; }
  .rewrite-list { margin: 1.25rem 0; display: flex; flex-direction: column; gap: 0.6rem; max-width: 44rem; }
  .rewrite-list li { color: rgba(247, 243, 236, 0.72); line-height: 1.6; padding-left: 1.5rem; position: relative; }
  .rewrite-list li::before { content: '✓'; position: absolute; left: 0; color: var(--red-soft); }
  .rewrite-alt { color: rgba(247, 243, 236, 0.6); }
  .rewrite-alt strong { color: var(--cream); }
</style>
