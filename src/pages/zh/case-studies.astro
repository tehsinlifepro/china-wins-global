---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const cases = (await getCollection('caseStudies', ({ data }) => data.lang === 'zh' && !data.draft))
  .sort((a, b) => (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0));
---

<BaseLayout
  lang="zh"
  title="客户案例 —— 中国赢全球"
  description="真实结果：中国供应商如何在领英上赢得西方 B2B 客户。"
>
  <section class="chapter chapter--light">
    <div class="wrap">
      <p class="eyebrow"><i></i><span>案例</span></p>
      <h1 class="h2">用结果说话，而非承诺。</h1>
      <p class="page-lead">供应商、货代与工厂，如何把空白的领英形象，变成源源不断的西方买家管道。</p>

      {cases.length > 0 && (
        <div class="cs-grid">
          {cases.map((c) => (
            <article class="cs-card">
              {c.data.industry && <span class="cs-industry">{c.data.industry}</span>}
              <h3>{c.data.title}</h3>
              <p>{c.data.description}</p>
            </article>
          ))}
        </div>
      )}

      <div class="cs-cta">
        <p class="page-lead" style="margin-top:0">随着现有客户达成里程碑，新的案例正在陆续发布。想成为其中之一？</p>
        <a class="btn btn--primary" href="/zh/contact/"><span>免费领取领英诊断</span></a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .cs-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; margin: 2.5rem 0; }
  .cs-card { padding: 1.75rem; border: 1px solid var(--hairline); border-radius: 1.25rem; background: var(--paper); }
  .cs-industry { display: inline-block; font-size: 0.75rem; letter-spacing: 0.06em; color: var(--red); margin-bottom: 0.5rem; }
  .cs-card h3 { font-family: var(--font-display); font-size: 1.4rem; margin-bottom: 0.5rem; }
  .cs-card p { color: var(--muted); line-height: 1.65; }
  .cs-cta { margin-top: 2.5rem; padding-top: 2.5rem; border-top: 1px solid var(--hairline); }
  .cs-cta .btn { margin-top: 1.25rem; }
  @media (max-width: 640px) { .cs-grid { grid-template-columns: 1fr; } }
</style>
