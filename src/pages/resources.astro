---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadMagnet from '../components/LeadMagnet.astro';
import { magnets } from '../data/leadMagnets';

const grid = ['01', '02', '03', '04', '07', '09'];
---

<BaseLayout
  title="Free Resources — China Wins Global"
  description="Free, branded playbooks and scorecards on building a LinkedIn presence that turns cold contacts into Western B2B clients."
>
  <section class="chapter chapter--light">
    <div class="wrap">
      <p class="eyebrow"><i></i><span>Free resources · 免费资源</span></p>
      <h1 class="h2">Playbooks for winning Western buyers.</h1>
      <p class="page-lead">Practical, no-fluff guides on turning LinkedIn into a client pipeline. Free branded PDFs — enter your email and we’ll send the download.</p>

      <div class="mag-featured">
        <LeadMagnet magnet={magnets['05'].en} file={magnets['05'].file} lang="en" featured />
      </div>

      <div class="mag-grid">
        {grid.map((id) => <LeadMagnet magnet={magnets[id].en} file={magnets[id].file} lang="en" />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .mag-featured { margin: 2.5rem 0 1.5rem; }
  .mag-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  @media (max-width: 900px) { .mag-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .mag-grid { grid-template-columns: 1fr; } }
</style>
