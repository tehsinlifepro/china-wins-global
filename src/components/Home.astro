---
import { home } from '../data/home';
import { magnets } from '../data/leadMagnets';
import LeadMagnet from './LeadMagnet.astro';
import AuditForm from './AuditForm.astro';
import '../styles/home.css';

interface Props { lang: 'en' | 'zh'; }
const { lang } = Astro.props;
const c = home[lang];
const p = lang === 'zh' ? '/zh' : '';
---

<div class="home">
  <!-- signature red thread, drawn on scroll -->
  <svg class="home-thread" id="homeThread" aria-hidden="true" preserveAspectRatio="none" viewBox="0 0 100 100">
    <path id="homeThreadPath" d="M 52 0 C 12 9, 90 20, 50 30 C 14 39, 88 51, 50 60 C 16 69, 84 80, 50 88 C 30 94, 66 97, 50 100" />
  </svg>

  <!-- 1 · HERO -->
  <section class="chapter chapter--light">
    <div class="wrap home-hero__grid">
      <div class="home-hero__copy">
        <p class="eyebrow"><i></i><span>{c.hero.eyebrow}</span></p>
        <h1 class="hero__title"><span>{c.hero.t1}</span><br /><span set:html={c.hero.t2} /></h1>
        <p class="hero__sub">{c.hero.sub}</p>
        {c.hero.gloss && <p class="gloss" lang="zh-CN">{c.hero.gloss}</p>}
        <div class="hero__ctas">
          <a class="btn btn--primary" href={`${p}/contact/`}>
            <span>{c.hero.ctaPrimary}</span>
            <span class="btn__orb" aria-hidden="true"><svg viewBox="0 0 16 16"><path d="M3 13 13 3M6 3h7v7" fill="none" stroke="currentColor" stroke-width="1.5"/></svg></span>
          </a>
          <a class="link-underline" href="#engine">{c.hero.ctaSecondary}</a>
        </div>
        <p class="hero__trust"><span>{c.hero.trust1}</span><i class="tick" aria-hidden="true"></i><span>{c.hero.trust2}</span></p>
      </div>
      <div class="home-hero__visual" aria-hidden="true">
        <div class="bezel">
          <div class="bezel__core">
            <p class="booth-card__label">{c.hero.card.label}</p>
            <div class="msg">
              <span class="msg__avatar">JS</span>
              <div>
                <p class="msg__name">{c.hero.card.name1}</p>
                <p class="msg__text">{c.hero.card.msg1}</p>
              </div>
            </div>
            <div class="msg msg--you">
              <span class="msg__avatar msg__avatar--you">你</span>
              <div>
                <p class="msg__name">{c.hero.card.name2}</p>
                <p class="msg__text">{c.hero.card.msg2}</p>
              </div>
            </div>
            <p class="booth-card__foot"><span class="pulse" aria-hidden="true"></span><span>{c.hero.card.foot}</span></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2 · THE SHIFT -->
  <section class="chapter chapter--dark">
    <div class="wrap">
      <p class="eyebrow eyebrow--dark"><i></i><span>{c.shift.eyebrow}</span></p>
      <div class="shift__grid">
        <div class="shift__body">
          <h2 class="h2 h2--dark">{c.shift.title}</h2>
          {c.shift.body.map((para) => <p>{para}</p>)}
        </div>
        <div class="shift__stat">
          <div class="shift__stat-num">{c.shift.stat}</div>
          <p class="shift__stat-cap">{c.shift.statCaption}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3 · WHO WE HELP (bento) -->
  <section class="chapter chapter--light">
    <div class="wrap">
      <p class="eyebrow"><i></i><span>{c.who.eyebrow}</span></p>
      <h2 class="h2">{c.who.title}</h2>
      <div class="bento">
        {c.who.cards.map((card) => (
          <a class="bento__card" href={card.href}>
            <span class="bento__seal" aria-hidden="true">{card.seal}</span>
            <h3>{card.title}</h3>
            <p>{card.desc}</p>
            <span class="bento__go" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 4 · THE ENGINE -->
  <section class="chapter chapter--light" id="engine">
    <div class="wrap">
      <p class="eyebrow"><i></i><span>{c.engine.eyebrow}</span></p>
      <h2 class="h2">{c.engine.title}</h2>
      <p class="home-lede">{c.engine.lede}</p>
      <div class="steps">
        {c.engine.steps.map((s) => (
          <div class="step">
            <span class="step__n">{s.n}</span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
      <div class="deliver-row">
        {c.engine.deliverables.map((d) => <span class="deliver-pill">{d}</span>)}
      </div>
    </div>
  </section>

  <!-- 5 · PROOF / GUARANTEE -->
  <section class="chapter chapter--dark">
    <div class="wrap">
      <div class="statement">
        <p class="eyebrow eyebrow--dark" style="justify-content:center"><i></i><span>{c.proof.eyebrow}</span></p>
        <h2 class="h2 h2--dark">{c.proof.title}</h2>
        <p class="home-lede" style="color:rgba(247,243,236,.7);margin-inline:auto">{c.proof.body}</p>
        <p class="statement__note">{c.proof.note}</p>
      </div>
    </div>
  </section>

  <!-- 6 · FREE RESOURCE -->
  <section class="chapter chapter--light">
    <div class="wrap">
      <p class="eyebrow"><i></i><span>{c.resource.eyebrow}</span></p>
      <h2 class="h2">{c.resource.title}</h2>
      <p class="home-lede">{c.resource.lede}</p>
      <div class="resource-band" style="margin-top:1.75rem">
        <LeadMagnet magnet={magnets['05'][lang]} file={magnets['05'].file} lang={lang} featured />
      </div>
    </div>
  </section>

  <!-- 7 · CHINA BAND -->
  <section class="chapter china-band">
    <div class="wrap"><p>{c.china}</p></div>
  </section>

  <!-- 8 · FINAL CTA -->
  <section class="chapter chapter--dark final" id="final">
    <div class="wrap final__inner">
      <p class="eyebrow eyebrow--dark"><i></i><span>{c.final.eyebrow}</span></p>
      <h2 class="h2 h2--dark">{c.final.title}</h2>
      <p class="home-lede" style="color:rgba(247,243,236,.7)">{c.final.sub}</p>
      <div style="margin-top:1.75rem"><AuditForm lang={lang} /></div>
    </div>
  </section>
</div>
