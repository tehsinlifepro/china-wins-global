---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadMagnet from '../../components/LeadMagnet.astro';
import { magnets } from '../../data/leadMagnets';

const grid = ['01', '02', '03', '04', '07', '09'];
---

<BaseLayout
  lang="zh"
  title="免费资源 —— 中国赢全球"
  description="免费、精心设计的实操手册与评分表，助你打造把陌生联系人变成西方 B2B 客户的领英形象。"
>
  <section class="chapter chapter--light">
    <div class="wrap">
      <p class="eyebrow"><i></i><span>免费资源</span></p>
      <h1 class="h2">赢得西方买家的实操手册。</h1>
      <p class="page-lead">务实、不灌水的指南，教你把领英变成客户管道。免费精美 PDF——留下邮箱，我们把下载链接发给你。</p>

      <div class="mag-featured">
        <LeadMagnet magnet={magnets['05'].zh} file={magnets['05'].file} lang="zh" featured />
      </div>

      <div class="mag-grid">
        {grid.map((id) => <LeadMagnet magnet={magnets[id].zh} file={magnets[id].file} lang="zh" />)}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .mag-featured { margin: 2.5rem 0 1.5rem; }
  .mag-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  @media (max-width: 900px) { .mag-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .mag-grid { grid-template-columns: 1fr; } }
</style>
